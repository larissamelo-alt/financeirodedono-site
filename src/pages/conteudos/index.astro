---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Pega todos os artigos, esconde rascunhos, ordena do mais novo pro mais antigo.
const artigos = (await getCollection("conteudos", ({ data }) => !data.rascunho))
  .sort((a, b) => b.data.data.valueOf() - a.data.data.valueOf());

function formatarData(d: Date) {
  return d.toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}
---

<BaseLayout
  titulo="Conteúdos — Financeiro de Dono"
  descricao="Materiais práticos sobre gestão financeira, fluxo de caixa e tomada de decisão para donos de empresas de serviço."
>
  <main class="mx-auto max-w-4xl px-5 py-12 md:py-16">
    <header class="mb-12">
      <a href="/" class="text-sm text-muted-foreground hover:text-foreground"
        >← Voltar para o site</a
      >
      <h1 class="mt-4 text-4xl font-bold text-foreground">Conteúdos</h1>
      <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
        Como organizar o financeiro, ganhar previsibilidade e decidir sem
        quebrar o caixa. Sem enrolação.
      </p>
    </header>

    {
      artigos.length === 0 ? (
        <p class="text-muted-foreground">
          Nenhum conteúdo publicado ainda. Em breve.
        </p>
      ) : (
        <ul class="space-y-4">
          {artigos.map((artigo) => (
            <li>
              <a
                href={`/conteudos/${artigo.slug}`}
                class="block rounded-xl border border-border bg-card p-6 transition hover:border-primary/40 hover:shadow-sm"
              >
                <p class="text-xs font-medium uppercase tracking-wide text-primary">
                  {artigo.data.categoria}
                </p>
                <h2 class="mt-2 text-xl font-semibold text-foreground">
                  {artigo.data.titulo}
                </h2>
                <p class="mt-2 text-muted-foreground">{artigo.data.descricao}</p>
                <p class="mt-4 text-sm text-muted-foreground">
                  {formatarData(artigo.data.data)}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
